    {
      "name": "Books",
      "item": [
        {
          "name": "List Books - GET /books",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/books?page=1&limit=10&keyword=",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "books"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "keyword",
                  "value": ""
                }
              ]
            }
          }
        },
        {
          "name": "Create Book (Admin) - POST /books",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.id) {",
                  "  pm.collectionVariables.set('bookId', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Node API for Newbie\",\n  \"author\": \"Teacher Demo\",\n  \"isbn\": \"9780000000001\",\n  \"published_year\": 2026,\n  \"total_copies\": 4\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/books",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "books"
              ]
            }
          }
        },
        {
          "name": "Get Book Detail - GET /books/{id}",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/books/{{bookId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "books",
                "{{bookId}}"
              ]
            }
          }
        },
        {
          "name": "Update Book (Admin) - PATCH /books/{id}",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
